module Templates.Disclosure where

import DA.Date

template RegulatoryDisclosure
  with
    regulator: Party
    reportId: Text
    reportPeriodStart: Date
    reportPeriodEnd: Date
    notionalBucket: Text
    assetClass: Text
    maturityBucket: Text
    counterpartyLeis: [Text]
    tradeCount: Int
    totalGrossNotional: Decimal
    generatedAt: Date
    schemaVersion: Text
  where
    signatory regulator
    observer regulator

    choice GetDisclosure: RegulatoryDisclosure
      controller regulator
      do
        return this

template RegulatoryDisclosureRequest
  with
    requestId: Text
    regulator: Party
    platformOperator: Party
    reportPeriodStart: Date
    reportPeriodEnd: Date
    requestedAt: Date
    fulfilled: Bool
  where
    signatory regulator, platformOperator
    observer platformOperator

    choice Fulfill: ContractId RegulatoryDisclosure
      with
        notionalBucket: Text
        assetClass: Text
        maturityBucket: Text
        counterpartyLeis: [Text]
        tradeCount: Int
        totalGrossNotional: Decimal
        generatedAt: Date
        schemaVersion: Text
      controller platformOperator
      do
        create RegulatoryDisclosure with
          regulator
          reportId = requestId
          reportPeriodStart
          reportPeriodEnd
          notionalBucket
          assetClass
          maturityBucket
          counterpartyLeis
          tradeCount
          totalGrossNotional
          generatedAt
          schemaVersion

    choice CancelRequest: ()
      controller regulator
      do
        return ()
