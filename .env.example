# JWT access token for Canton JSON Ledger API v2.
# Obtain via Authentik OIDC device-code flow or Seaport dashboard.
# If unset, API calls will fail with 401 Unauthorized.
CANTON_ACCESS_TOKEN=

# Semicolon-separated list of Party IDs authorized to access the app.
# Overrides the hardcoded default allowlist.
# Format: "party1;party2;party3"
ALLOWED_PARTY_IDS=

# URL of the Wallet Gateway for CIP-103 dApp integration.
# Not yet implemented — reserved for future use.
WALLET_GATEWAY_URL=
